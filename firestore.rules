rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Basic Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('isAdminModeEnabled', false) == true;
    }

    function isBanned(quizId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/banned_users/$( "global_" + request.auth.uid )) ||
        (quizId != null && exists(/databases/$(database)/documents/banned_users/$(quizId + "_" + request.auth.uid)))
      );
    }

    function isAllowedToAttempt(quizId) {
      return !exists(/databases/$(database)/documents/quizzes/$(quizId)) || (
        get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false &&
        get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isLocked', false) == false &&
        !isBanned(quizId) &&
        (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('activeAt', null) == null || get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('activeAt') <= request.time) &&
        (
          (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
            (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isRestricted', false) == false || (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('allowedParticipants', [])))
          ) ||
          (isAuthenticated() && (
            (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'protected' && request.auth.uid in get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('allowedParticipants', [])) ||
            get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('creatorId', '') == request.auth.uid ||
            isGlobalAdmin()
          ))
        )
      );
    }

    function hasQuizPermission(quizId, permission) {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)) &&
             get(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)).data.get('permissions', {}).get(permission, false) == true;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isGlobalAdmin();
      match /protected/details { allow read, write: if isOwner(userId) || isGlobalAdmin(); }
      match /private/details { allow read, write: if isOwner(userId) || isGlobalAdmin(); }
    }

    match /quizzes/{quizId} {
      allow read: if (resource.data.get('visibility', 'private') == 'public' && resource.data.get('isDeleted', false) == false) ||
                   isGlobalAdmin() ||
                   (isAuthenticated() && (
                     (resource.data.get('visibility', 'private') == 'protected' && request.auth.uid in resource.data.get('allowedParticipants', [])) ||
                     resource.data.get('creatorId', '') == request.auth.uid
                   ));
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isGlobalAdmin() ||
                    (isAuthenticated() && (resource.data.get('creatorId', '') == request.auth.uid || hasQuizPermission(quizId, 'canUpdateData')));
      allow delete: if isGlobalAdmin() || (isAuthenticated() && resource.data.get('creatorId', '') == request.auth.uid);
    }

    match /quiz_questions/{quizId} {
      allow read: if (exists(/databases/$(database)/documents/quizzes/$(quizId)) &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false) ||
                   isAllowedToAttempt(quizId) ||
                   isGlobalAdmin() ||
                   hasQuizPermission(quizId, 'canSeeResponses');
      allow write: if isGlobalAdmin() || hasQuizPermission(quizId, 'canUpdateData');
    }

    match /answer_keys/{quizId} {
      allow read: if (exists(/databases/$(database)/documents/quizzes/$(quizId)) &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false) ||
                   isAllowedToAttempt(quizId) ||
                   isGlobalAdmin() ||
                   hasQuizPermission(quizId, 'canSeeResponses');
      allow write: if isGlobalAdmin() || hasQuizPermission(quizId, 'canUpdateData');
    }

    match /responses/{responseId} {
      allow read: if isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || isGlobalAdmin() || hasQuizPermission(resource.data.get('quizId', ''), 'canSeeResponses'));
      allow create: if isAuthenticated() && isAllowedToAttempt(request.resource.data.get('quizId', ''));
      allow update: if isGlobalAdmin() || (isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || hasQuizPermission(resource.data.get('quizId', ''), 'canModerate')));
    }

    match /quiz_attempts/{quizId} {
      allow read: if isGlobalAdmin() || hasQuizPermission(quizId, 'canSeeResponses');
      match /attempts/{attemptId} {
        allow read: if isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || isGlobalAdmin() || hasQuizPermission(quizId, 'canSeeResponses'));
        allow create: if isAuthenticated() && isAllowedToAttempt(quizId);
      }
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /settings/{docId} { allow read: if true; allow write: if isGlobalAdmin(); }
    match /feature_flags/{docId} { allow read: if true; allow create, update, delete: if isGlobalAdmin(); }
    match /admins/{userId} { allow read: if isAuthenticated(); allow update: if isOwner(userId); allow write: if isGlobalAdmin(); }
    match /quiz_access/{accessId} { allow read: if isAuthenticated() && (resource.data.get('userId', '') == request.auth.uid || isGlobalAdmin()); allow write: if isGlobalAdmin(); }
    match /banned_users/{banId} { allow read: if isAuthenticated() && (banId == ("global_" + request.auth.uid) || banId.matches(".*_" + request.auth.uid) || isGlobalAdmin()); allow write: if isGlobalAdmin(); }
    match /audit_logs/{logId} { allow create: if isAuthenticated(); allow read: if isGlobalAdmin(); }
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && resource.data.get('userId', '') == request.auth.uid;
      allow create, delete: if isGlobalAdmin();
    }
  }
}
