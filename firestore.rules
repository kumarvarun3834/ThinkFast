rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null && !isBlocked();
    }

    // Check if user is in the global block list
    function isBlocked() {
      let moderation = get(/databases/$(database)/documents/settings/moderation).data;
      return request.auth.uid in moderation.get('blocked_uids', []);
    }

    // Check if user has moderator/admin privileges
    function isModerator() {
      let adminUid = 'y6IkZpvVBYZWvVzXwJTfcwC3EBu2'; // Super Admin
      return request.auth != null && (request.auth.uid == adminUid || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Check for specific admin permission
    function hasAdminPermission(permission) {
      let adminUid = 'y6IkZpvVBYZWvVzXwJTfcwC3EBu2';
      if (request.auth.uid == adminUid) return true;
      if (!exists(/databases/$(database)/documents/admins/$(request.auth.uid))) return false;
      let adminDoc = get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
      return adminDoc.get('allowed_features', []).contains(permission);
    }

    function getQuiz(quizId) {
      return get(/databases/$(database)/documents/databases/$(quizId)).data;
    }

    // Checks if the user is the creator of the quiz
    function isCreator(quizId) {
      return isAuthenticated() && getQuiz(quizId).creatorId == request.auth.uid;
    }

    // Checks if the quiz is accessible (public and not deleted)
    function isQuizAccessible(quizId) {
      let quiz = getQuiz(quizId);
      return quiz.visibility == 'public' && quiz.get('isDeleted', false) == false;
    }

    // --- Collection Rules ---

    // 1. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if (isAuthenticated() && request.auth.uid == userId) || isModerator();

      match /private/details {
         allow read, write: if (isAuthenticated() && request.auth.uid == userId) || isModerator();
      }
    }

    // 2. Quiz Metadata
    match /databases/{quizId} {
      allow create: if isAuthenticated() && (request.resource.data.creatorId == request.auth.uid || isModerator());
      allow read: if (resource.data.get('visibility', 'private') == 'public' && resource.data.get('isDeleted', false) == false) ||
                   (isAuthenticated() && resource.data.creatorId == request.auth.uid) || isModerator();
      allow update, delete: if (isAuthenticated() && resource.data.creatorId == request.auth.uid) || isModerator();
    }

    // 3. Quiz Questions
    match /quiz_questions/{quizId} {
      allow read: if isQuizAccessible(quizId) || isCreator(quizId) || isModerator();
      allow write: if (isCreator(quizId) || isModerator()) && !exists(/databases/$(database)/documents/quiz_questions/$(quizId));
    }

    // 4. Answer Keys
    match /answer_keys/{quizId} {
      allow read: if isQuizAccessible(quizId) || isCreator(quizId) || isModerator();
      allow write: if (isCreator(quizId) || isModerator()) && !exists(/databases/$(database)/documents/answer_keys/$(quizId));
    }

    // 5. Responses / Attempts
    match /responses/{responseId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isCreator(resource.data.quizId) || isModerator());
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isModerator();
      allow delete: if isModerator();
    }

    // --- Settings / Feature Flags ---
    match /settings/features {
      allow read: if true;
      allow write: if isModerator();
    }

    match /settings/moderation {
      allow read, write: if isModerator();
    }

    // 6. Admin Permissions
    match /admins/{adminId} {
      allow read: if isAuthenticated() && (request.auth.uid == adminId || isModerator());
      allow write: if isModerator(); // Only existing admins or super admin can add new ones
    }
  }
}
