rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Basic Helpers ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isGlobalAdmin() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('isAdminModeEnabled', false) == true;
    }

    function hasGlobalPermission(permission) {
      return isGlobalAdmin() && (
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('level', 1) == 0 ||
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('permissions', {}).get(permission, false) == true
      );
    }

    function isBanned(quizId) {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/banned_users/$( "global_" + request.auth.uid )) ||
        (quizId != null && exists(/databases/$(database)/documents/banned_users/$(quizId + "_" + request.auth.uid)))
      );
    }

    function isAllowedToAttempt(quizId) {
      return exists(/databases/$(database)/documents/quizzes/$(quizId)) && (
        isGlobalAdmin() ||
        isQuizOwner(quizId) ||
        (
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false &&
          get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isLocked', false) == false &&
          !isBanned(quizId) &&
          (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('activeAt', null) == null || get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('activeAt', request.time) <= request.time) &&
          (
            (isAuthenticated() && exists(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid))) ||
            (isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('allowedParticipants', [])) ||
            (get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
             get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isRestricted', false) == false)
          )
        )
      );
    }

    function hasQuizPermission(quizId, permission) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)).data.get('permissions', {}).get(permission, false) == true;
    }

    function isQuizOwner(quizId) {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('creatorId', '') == request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || hasGlobalPermission('moderate_users');
      match /protected/details { allow read, write: if isOwner(userId) || hasGlobalPermission('moderate_users'); }
      match /private/details { allow read, write: if isOwner(userId) || hasGlobalPermission('moderate_users'); }
    }

    match /devices/{userId} {
      allow read, write: if isOwner(userId) || isGlobalAdmin();
      match /active_device/{deviceId} {
        allow read, write: if isOwner(userId) || isGlobalAdmin();
      }
    }

    match /quizzes/{quizId} {
      allow read: if (resource.data.get('visibility', 'private') == 'public' && resource.data.get('isDeleted', false) == false) ||
                   isGlobalAdmin() ||
                   (isAuthenticated() && resource.data.get('creatorId', '') == request.auth.uid) ||
                   (isAuthenticated() && (
                     exists(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)) ||
                     request.auth.uid in resource.data.get('allowedParticipants', [])
                   ));
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if hasGlobalPermission('manage_all_quizzes') ||
                    (isAuthenticated() && (
                      resource.data.get('creatorId', '') == request.auth.uid ||
                      hasQuizPermission(quizId, 'can_update') ||
                      hasQuizPermission(quizId, 'can_publish')
                    ));
      allow delete: if hasGlobalPermission('manage_all_quizzes') ||
                    (isAuthenticated() && (resource.data.get('creatorId', '') == request.auth.uid || hasQuizPermission(quizId, 'can_delete')));
    }

    match /quiz_questions/{quizId} {
      allow read: if (exists(/databases/$(database)/documents/quizzes/$(quizId)) &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false) ||
                   isAllowedToAttempt(quizId) ||
                   isGlobalAdmin() ||
                   isQuizOwner(quizId) ||
                   hasQuizPermission(quizId, 'can_view_results') ||
                   hasQuizPermission(quizId, 'can_moderate');
      allow write: if hasGlobalPermission('manage_all_quizzes') || isQuizOwner(quizId) || hasQuizPermission(quizId, 'can_update');
    }

    match /answer_keys/{quizId} {
      allow read: if (exists(/databases/$(database)/documents/quizzes/$(quizId)) &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('visibility', 'private') == 'public' &&
                      get(/databases/$(database)/documents/quizzes/$(quizId)).data.get('isDeleted', false) == false) ||
                   isAllowedToAttempt(quizId) ||
                   isGlobalAdmin() ||
                   isQuizOwner(quizId) ||
                   hasQuizPermission(quizId, 'can_view_results') ||
                   hasQuizPermission(quizId, 'can_moderate');
      allow write: if hasGlobalPermission('manage_all_quizzes') || isQuizOwner(quizId) || hasQuizPermission(quizId, 'can_update');
    }

    match /responses/{responseId} {
      allow read: if isAuthenticated() && (
        resource.data.get('userId', '') == request.auth.uid ||
        isGlobalAdmin() ||
        isQuizOwner(resource.data.get('quizId', '')) ||
        hasQuizPermission(resource.data.get('quizId', ''), 'can_view_results') ||
        hasQuizPermission(resource.data.get('quizId', ''), 'can_moderate')
      );
      allow create: if isAuthenticated() && isAllowedToAttempt(request.resource.data.get('quizId', ''));
      allow update: if hasGlobalPermission('moderate_users') || (isAuthenticated() && (
        resource.data.get('userId', '') == request.auth.uid ||
        isQuizOwner(resource.data.get('quizId', '')) ||
        hasQuizPermission(resource.data.get('quizId', ''), 'can_moderate')
      ));
    }

    match /quiz_attempts/{quizId} {
      allow read: if isGlobalAdmin() || isQuizOwner(quizId) || hasQuizPermission(quizId, 'can_view_results') || hasQuizPermission(quizId, 'can_moderate');
      match /attempts/{attemptId} {
        allow read: if isAuthenticated() && (
          resource.data.get('userId', '') == request.auth.uid ||
          isGlobalAdmin() ||
          isQuizOwner(quizId) ||
          hasQuizPermission(quizId, 'can_view_results') ||
          hasQuizPermission(quizId, 'can_moderate')
        );
        allow create: if isAuthenticated() && isAllowedToAttempt(quizId);
        allow update: if hasGlobalPermission('moderate_users') || (isAuthenticated() && (
          resource.data.get('userId', '') == request.auth.uid ||
          isQuizOwner(quizId) ||
          hasQuizPermission(quizId, 'can_moderate')
        ));
        allow delete: if hasGlobalPermission('moderate_users') || isQuizOwner(quizId);
      }
    }

    match /tags/{tagId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /module_tags/{docId} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        isGlobalAdmin() ||
        isQuizOwner(request.resource.data.quizId) ||
        hasQuizPermission(request.resource.data.quizId, 'can_update')
      );
    }

    match /exam_tags/{tagId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if (docId == 'admin' && hasGlobalPermission('manage_admins')) ||
                      (docId == 'ai' && hasGlobalPermission('bypass_ai_quotas')) ||
                      (docId != 'admin' && docId != 'ai' && hasGlobalPermission('manage_app_settings'));
    }

    match /feature_flags/{docId} {
      allow read: if docId == 'public' || isGlobalAdmin();
      allow write: if (docId == 'public' && hasGlobalPermission('manage_app_settings')) ||
                      (docId == 'admin' && hasGlobalPermission('manage_admins')) ||
                      (docId == 'moderation' && hasGlobalPermission('moderate_users')) ||
                      (docId == 'ai' && hasGlobalPermission('bypass_ai_quotas')) ||
                      (docId == 'quizzes' && hasGlobalPermission('manage_all_quizzes')) ||
                      (docId == 'logs' && hasGlobalPermission('view_audit_logs')) ||
                      (docId == 'collaboration' && hasGlobalPermission('manage_collaborators'));
    }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow update: if isOwner(userId) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isAdminModeEnabled', 'updatedAt']);
      allow create, delete, update: if hasGlobalPermission('manage_admins') && (
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('level', 1) == 0 ||
        (
          (resource == null || resource.data.get('level', 1) != 0) &&
          (request.resource == null || request.resource.data.get('level', 1) != 0)
        )
      );
    }

    match /quiz_access/{accessId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isGlobalAdmin() ||
        (resource.data.quizId != null && (
          isQuizOwner(resource.data.quizId) ||
          hasQuizPermission(resource.data.quizId, 'can_manage_collaborators') ||
          exists(/databases/$(database)/documents/quiz_access/$(resource.data.quizId + "_" + request.auth.uid))
        ))
      );
      allow create, update, delete: if hasGlobalPermission('manage_collaborators') ||
                                     (request.resource.data.quizId != null && (
                                       isQuizOwner(request.resource.data.quizId) ||
                                       hasQuizPermission(request.resource.data.quizId, 'can_manage_collaborators')
                                     ));
    }

    match /banned_users/{banId} {
      allow read: if isAuthenticated() && (
        banId == ("global_" + request.auth.uid) ||
        banId.matches(".*_" + request.auth.uid) ||
        isGlobalAdmin() ||
        (resource != null && (
          isQuizOwner(resource.data.get('quizId', '')) ||
          hasQuizPermission(resource.data.get('quizId', ''), 'can_moderate') ||
          hasQuizPermission(resource.data.get('quizId', ''), 'can_ban_users')
        ))
      );
      allow create, update, delete: if hasGlobalPermission('moderate_users') || (
        (request.resource != null && request.resource.data.get('quizId', null) != null && (
          isQuizOwner(request.resource.data.quizId) ||
          hasQuizPermission(request.resource.data.quizId, 'can_ban_users')
        )) ||
        (resource != null && resource.data.get('quizId', null) != null && (
          isQuizOwner(resource.data.quizId) ||
          hasQuizPermission(resource.data.quizId, 'can_ban_users')
        ))
      );
    }

    match /audit_logs/{logId} {
      allow create: if isAuthenticated() || true; // Allow security logs during failed login
      allow read: if hasGlobalPermission('view_audit_logs');
      allow delete: if isGlobalAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('level', 1) == 0;
    }

    match /security_logs/{logId} {
      // Brute-force protection tracking
      allow read: if isGlobalAdmin();
      allow create, update: if true; // Public access required for IP logging on failed auth
    }

    match /content_reports/{reportId} {
      // UGC Reporting
      allow create: if isAuthenticated();
      allow read: if hasGlobalPermission('view_audit_logs') || hasGlobalPermission('manage_app_settings');
      allow update, delete: if isGlobalAdmin();
    }

    match /user_usage/{userId} {
      // AI Quota tracking
      allow read: if isOwner(userId) || isGlobalAdmin();
      allow write: if isOwner(userId) || isGlobalAdmin();
    }

    match /ai_generations/{genId} {
      // AI Generation history
      allow create: if isAuthenticated();
      allow read: if isGlobalAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && resource.data.get('userId', '') == request.auth.uid;
      allow create, delete: if isGlobalAdmin();
    }

    match /global_notifications/{notifId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isGlobalAdmin();
    }

    match /leaderboards/{quizId} {
      allow read: if (resource == null || resource.data.get('isPublic', true) == true) ||
                   isGlobalAdmin() ||
                   isAuthenticated() && (
                     exists(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)) ||
                     isQuizOwner(quizId)
                   );
      allow write: if hasGlobalPermission('manage_leaderboards') ||
                    (isAuthenticated() && (
                      isQuizOwner(quizId) ||
                      get(/databases/$(database)/documents/quiz_access/$(quizId + "_" + request.auth.uid)).data.permissions.get('canModerate', false) == true
                    ));
    }
  }
}
