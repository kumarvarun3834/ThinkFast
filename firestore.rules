rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Global App Admin Check
    function isGlobalAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
         request.auth.uid == 'y6IkZpvVBYZWvVzXwJTfcwC3EBu2');
    }

    // 2. Quiz-Specific Manager Check (Delegated Admin)
    function hasQuizPermission(quizId, permission) {
      let accessId = quizId + "_" + request.auth.uid;
      let accessPath = /databases/$(database)/documents/quiz_access/$(accessId);
      return isAuthenticated() && (
        exists(accessPath) && get(accessPath).data.permissions.get(permission, false) == true
      );
    }

    function getQuiz(quizId) {
      return get(/databases/$(database)/documents/quizzes/$(quizId)).data;
    }

    function isQuizCreator(quizId) {
      return isAuthenticated() && getQuiz(quizId).creatorId == request.auth.uid;
    }

    // Helper to check if user has ANY management right over a quiz (Creator, Delegated Admin, or Global Admin)
    function canManageQuiz(quizId, permission) {
      return isQuizCreator(quizId) || hasQuizPermission(quizId, permission) || isGlobalAdmin();
    }

    // --- Collection Rules ---

    // 1. User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isGlobalAdmin();

      match /protected/details {
        allow read: if isOwner(userId) || isGlobalAdmin();
        allow write: if isOwner(userId) || isGlobalAdmin();
      }

      match /private/details {
        allow read, write: if isOwner(userId) || isGlobalAdmin();
      }
    }

    // 2. Quizzes (Main Metadata + Questions)
    match /quizzes/{quizId} {
      allow read: if resource.data.get('isDeleted', false) == false &&
                   (resource.data.get('visibility', 'private') == 'public' || isQuizCreator(quizId) || isGlobalAdmin());
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update: if canManageQuiz(quizId, 'can_update') || isGlobalAdmin();
      allow delete: if canManageQuiz(quizId, 'can_delete') || isGlobalAdmin();
    }

    // 3. Answer Keys (Security sensitive)
    match /answer_keys/{quizId} {
      allow read: if canManageQuiz(quizId, 'can_update') || canManageQuiz(quizId, 'can_view_results');
      allow write: if canManageQuiz(quizId, 'can_update');
    }

    // 4. Responses & Attempts
    match /responses/{responseId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isGlobalAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /all_attempts/{attemptId} {
      allow read: if isGlobalAdmin();
      allow create: if isAuthenticated();
    }

    match /quiz_attempts/{quizId} {
      allow read: if canManageQuiz(quizId, 'can_view_results');
      match /attempts/{attemptId} {
        allow read: if canManageQuiz(quizId, 'can_view_results');
        allow create: if isAuthenticated();
      }
    }

    // 5. App Settings & Feature Flags
    match /settings/{docId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    match /feature_flags/{docId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    // 6. Admin Management
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin();
    }

    // 7. Quiz Access & Bans
    match /quiz_access/{accessId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isQuizCreator(resource.data.quizId) || isGlobalAdmin());
      allow write: if isGlobalAdmin() || (request.resource.data.quizId != null && isQuizCreator(request.resource.data.quizId));
    }

    match /quiz_bans/{banId} {
      allow read: if isAuthenticated();
      allow write: if isGlobalAdmin() || (request.resource.data.quizId != null && canManageQuiz(request.resource.data.quizId, 'can_ban_users'));
    }

    // 8. Analytics & Stats
    match /quiz_stats/{quizId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    match /quiz_question_stats/{questionId} {
      allow read: if true;
      allow write: if isGlobalAdmin();
    }

    // 9. Reports (Users report, Admins review)
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, write: if isGlobalAdmin();
    }

    // 10. Audit Logs (Admin only)
    match /audit_logs/{logId} {
      allow read, write: if isGlobalAdmin();
    }

    // 11. Notifications
    match /notifications/{notifId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, delete: if isGlobalAdmin();
    }

    // 12. AI & Usage
    match /ai_generations/{genId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /user_usage/{userId} {
      allow read: if isOwner(userId) || isGlobalAdmin();
      allow write: if isGlobalAdmin();
    }
  }
}
